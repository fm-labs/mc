{
    "id": "traceroute",
    "name": "traceroute",
    "description": "",
    "version": "1.0",
    "commands": {
        "_docker": {
            "cmd": [
                "docker",
                "run",
                "--rm",
                "alpine:latest",
                "traceroute"
            ],
            "env": {},
            "options": {
                "pull_policy": null,
                "volumes": null,
                "workdir": null,
                "user": null,
                "entrypoint": null
            }
        },
        "_": {
            "cmd": [
                "traceroute",
                "{{target}}"
            ],
            "description": "Traces the route packets take to reach a destination host",
            "input_schema": {
                "type": "object",
                "properties": {
                    "target": {
                        "type": "string",
                        "description": "The target IP address or domain to trace"
                    }
                },
                "required": [
                    "target"
                ]
            },
            "output_schema": {
                "type": "string",
                "description": "The command output as a string."
            }
        },
        "with_max_hops": {
            "cmd": [
                "traceroute",
                "-m",
                "{{max_hops}}",
                "{{target}}"
            ],
            "description": "Traces the route with a specified maximum number of hops",
            "input_schema": {
                "type": "object",
                "properties": {
                    "target": {
                        "type": "string",
                        "description": "The target IP address or domain to trace"
                    },
                    "max_hops": {
                        "type": "integer",
                        "description": "Maximum number of hops to trace",
                        "default": 30
                    }
                },
                "required": [
                    "target"
                ]
            },
            "output_schema": {
                "type": "string",
                "description": "The command output as a string."
            }
        },
        "numeric": {
            "cmd": [
                "traceroute",
                "-n",
                "{{target}}"
            ],
            "description": "Traces the route without resolving hostnames to IP addresses",
            "input_schema": {
                "type": "object",
                "properties": {
                    "target": {
                        "type": "string",
                        "description": "The target IP address or domain to trace"
                    }
                },
                "required": [
                    "target"
                ]
            },
            "output_schema": {
                "type": "string",
                "description": "The command output as a string."
            }
        },
        "with_timeout": {
            "cmd": [
                "traceroute",
                "-w",
                "{{timeout}}",
                "{{target}}"
            ],
            "description": "Traces the route with a custom timeout for each probe",
            "input_schema": {
                "type": "object",
                "properties": {
                    "target": {
                        "type": "string",
                        "description": "The target IP address or domain to trace"
                    },
                    "timeout": {
                        "type": "integer",
                        "description": "Timeout in seconds for each probe",
                        "default": 5
                    }
                },
                "required": [
                    "target"
                ]
            },
            "output_schema": {
                "type": "string",
                "description": "The command output as a string."
            }
        }
    }
}