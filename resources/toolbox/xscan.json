{
    "id": "xscan",
    "name": "xscan",
    "description": "",
    "version": "1.0",
    "commands": {
        "_docker": {
            "cmd": [
                "docker",
                "run",
                "--rm",
                "kloudia-xscan:latest",
                "xscan"
            ],
            "env": {},
            "options": {
                "pull_policy": null,
                "volumes": null,
                "workdir": null,
                "user": null,
                "entrypoint": null
            }
        },
        "scan_repo": {
            "cmd": [
                "xscan",
                "repo",
                "{{repo_url}}",
                "--output-json"
            ],
            "description": "A tool that scans a git repository for vulnerabilities.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "repo_url": {
                        "type": "string",
                        "description": "The URL of the git repository to scan."
                    }
                },
                "required": [
                    "repo_url"
                ]
            },
            "output_schema": {
                "type": "string",
                "description": "The command output as a string."
            }
        },
        "scan_image": {
            "cmd": [
                "xscan",
                "image",
                "{{image_name}}",
                "--output-json"
            ],
            "description": "A tool that scans a container image for vulnerabilities.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "image_name": {
                        "type": "string",
                        "description": "The name of the container image to scan."
                    }
                },
                "required": [
                    "image_name",
                    "output_dir"
                ]
            },
            "output_schema": {
                "type": "string",
                "description": "The command output as a string."
            }
        }
    }
}