{
    "id": "dig",
    "name": "dig",
    "description": "",
    "version": "1.0",
    "commands": {
        "_docker": {
            "cmd": [
                "docker",
                "run",
                "--rm",
                "alpine:latest",
                "dig"
            ],
            "env": {},
            "options": {
                "pull_policy": null,
                "volumes": null,
                "workdir": null,
                "user": null,
                "entrypoint": null
            }
        },
        "_": {
            "cmd": [
                "dig",
                "{{domain}}"
            ],
            "description": "A tool that performs DNS lookup for a domain name.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "domain": {
                        "type": "string",
                        "description": "The domain name to lookup."
                    }
                },
                "required": [
                    "domain"
                ]
            },
            "output_schema": {
                "type": "string",
                "description": "The command output as a string."
            }
        },
        "mx_record": {
            "cmd": [
                "dig",
                "{{domain}}",
                "MX"
            ],
            "description": "A tool that queries MX records for a domain.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "domain": {
                        "type": "string",
                        "description": "The domain name to lookup MX records for."
                    }
                },
                "required": [
                    "domain"
                ]
            },
            "output_schema": {
                "type": "string",
                "description": "The command output as a string."
            }
        },
        "txt_record": {
            "cmd": [
                "dig",
                "{{domain}}",
                "TXT"
            ],
            "description": "A tool that queries TXT records for a domain.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "domain": {
                        "type": "string",
                        "description": "The domain name to lookup TXT records for."
                    }
                },
                "required": [
                    "domain"
                ]
            },
            "output_schema": {
                "type": "string",
                "description": "The command output as a string."
            }
        },
        "reverse_lookup": {
            "cmd": [
                "dig",
                "-x",
                "{{ip_address}}"
            ],
            "description": "A tool that performs reverse DNS lookup for an IP address.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "ip_address": {
                        "type": "string",
                        "description": "The IP address to perform reverse lookup for."
                    }
                },
                "required": [
                    "ip_address"
                ]
            },
            "output_schema": {
                "type": "string",
                "description": "The command output as a string."
            }
        },
        "trace": {
            "cmd": [
                "dig",
                "+trace",
                "{{domain}}"
            ],
            "description": "A tool that traces the delegation path from root name servers for a domain.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "domain": {
                        "type": "string",
                        "description": "The domain name to trace."
                    }
                },
                "required": [
                    "domain"
                ]
            },
            "output_schema": {
                "type": "string",
                "description": "The command output as a string."
            }
        },
        "short": {
            "cmd": [
                "dig",
                "+short",
                "{{domain}}"
            ],
            "description": "A tool that provides short answer format for DNS queries.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "domain": {
                        "type": "string",
                        "description": "The domain name to lookup."
                    }
                },
                "required": [
                    "domain"
                ]
            },
            "output_schema": {
                "type": "string",
                "description": "The command output as a string."
            }
        }
    }
}