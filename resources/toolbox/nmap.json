{
    "id": "nmap",
    "name": "nmap",
    "description": "",
    "version": "1.0",
    "commands": {
        "_docker": {
            "cmd": [
                "docker",
                "run",
                "--rm",
                "instrumentisto/nmap",
                "nmap"
            ],
            "env": {},
            "options": {
                "pull_policy": null,
                "volumes": null,
                "workdir": null,
                "user": null,
                "entrypoint": null
            }
        },
        "_": {
            "cmd": [
                "nmap",
                "-sV",
                "{{target}}"
            ],
            "description": "A tool that performs an nmap scan on the target.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "target": {
                        "type": "string",
                        "description": "The target IP address or domain to scan."
                    }
                },
                "required": [
                    "target"
                ]
            },
            "output_schema": {
                "type": "string",
                "description": "The command output as a string."
            }
        },
        "quick_scan": {
            "cmd": [
                "nmap",
                "-F",
                "{{target}}"
            ],
            "description": "A tool that performs a quick nmap scan on the target.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "target": {
                        "type": "string",
                        "description": "The target IP address or domain to scan."
                    }
                },
                "required": [
                    "target"
                ]
            },
            "output_schema": {
                "type": "string",
                "description": "The command output as a string."
            }
        },
        "top_ports": {
            "cmd": [
                "nmap",
                "--top-ports",
                "{{port_count}}",
                "{{target}}"
            ],
            "description": "A tool that scans the top N ports on the target.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "target": {
                        "type": "string",
                        "description": "The target IP address or domain to scan."
                    },
                    "port_count": {
                        "type": "integer",
                        "description": "The number of top ports to scan."
                    }
                },
                "required": [
                    "target",
                    "port_count"
                ]
            },
            "output_schema": {
                "type": "string",
                "description": "The command output as a string."
            }
        },
        "os_detect": {
            "cmd": [
                "nmap",
                "-O",
                "{{target}}"
            ],
            "description": "A tool that detects the operating system of the target.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "target": {
                        "type": "string",
                        "description": "The target IP address or domain to scan."
                    }
                },
                "required": [
                    "target"
                ]
            },
            "output_schema": {
                "type": "string",
                "description": "The command output as a string."
            }
        },
        "vuln_scan": {
            "cmd": [
                "nmap",
                "--script",
                "vuln",
                "{{target}}"
            ],
            "description": "A tool that performs a vulnerability scan on the target.",
            "input_schema": {
                "type": "object",
                "properties": {
                    "target": {
                        "type": "string",
                        "description": "The target IP address or domain to scan."
                    }
                },
                "required": [
                    "target"
                ]
            },
            "output_schema": {
                "type": "string",
                "description": "The command output as a string."
            }
        }
    }
}