{
  "type": "object",
  "title": "DNS Record",
  "description": "DNS record inventory item",
  "version": "1.0.0",
  "properties": {
    "domain": {
      "type": "string",
      "title": "Domain"
    },
    "type": {
      "type": "string",
      "title": "Type",
      "enum": [
        "A",
        "AAAA",
        "CNAME",
        "MX",
        "TXT",
        "SRV",
        "NS",
        "PTR"
      ]
    },
    "value": {
      "type": "string",
      "title": "Value"
    },
    "ttl": {
      "type": "integer",
      "title": "TTL (seconds)",
      "default": 3600
    },
    "priority": {
      "type": "integer",
      "title": "Priority",
      "default": 10
    }
  },
  "required": [
    "domain",
    "type",
    "value"
  ]
}