{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "App Template",
  "description": "An application template defines a reusable configuration for deploying an application using Docker Compose.",
  "version": "1.0.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "alias",
    "type",
    "title",
    "description",
    "categories",
    "platform",
    "repository"
  ],
  "properties": {
    "alias": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "enum": [
        "compose"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "note": {
      "type": "string"
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "platform": {
      "type": "string",
      "enum": [
        "linux",
        "windows",
        "mac"
      ]
    },
    "logo": {
      "type": "string"
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "url",
        "stackfile"
      ],
      "properties": {
        "url": {
          "type": "string",
          "format": "uri"
        },
        "stackfile": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "env": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "label"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "default": {
            "type": "string"
          }
        }
      }
    },
    "volumes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "bind",
          "container"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "bind": {
            "type": "string",
            "minLength": 1
          },
          "container": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "ports": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[0-9]+:[0-9]+/(tcp|udp)$"
      }
    },
    "labels": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "value"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "value": {
            "type": "string"
          }
        }
      }
    },
    "routes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "service",
          "containerPort",
          "protocol"
        ],
        "properties": {
          "serviceName": {
            "type": "string",
            "minLength": 1
          },
          "containerPort": {
            "type": "integer",
            "minimum": 1,
            "maximum": 65535
          },
          "protocol": {
            "type": "string",
            "enum": [
              "http",
              "https"
            ],
            "default": "https"
          }
        }
      }
    }
  }
}