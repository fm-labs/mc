{
  "type": "object",
  "title": "MCP Server",
  "description": "MCP Server inventory item",
  "version": "1.0.0",
  "properties": {
    "type": {
      "type": "string",
      "title": "MCP Transport Type",
      "enum": [
        "http",
        "stdio"
      ]
    },
    "url": {
      "type": "string",
      "title": "MCP Server URL (for HTTP transport)"
    },
    "command": {
      "type": "string",
      "title": "MCP Server Command (for stdio transport)"
    },
    "args": {
      "type": "string",
      "title": "MCP Server Command Arguments",
      "description": "Arguments to pass to the MCP server command when using stdio transport"
    },
    "env": {
      "type": "string",
      "title": "Environment Variables",
      "description": "Environment variables to set for the MCP server process (for stdio transport)"
    },
    "autoconnect": {
      "type": "boolean",
      "title": "Auto-connect",
      "default": true
    }
  },
  "required": ["type"]
}