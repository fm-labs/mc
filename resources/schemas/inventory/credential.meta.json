{
  "name": "Host",
  "pluralName": "Hosts",
  "description": "A single host entry in the inventory.",
  "icon": "server",
  "actions": [
    {
      "id": "configure",
      "name": "Configure credentials",
      "type": "form",
      "inputSchema": {
        "type": "object",
        "properties": {
          "pkey": {
            "type": "string",
            "title": "Private Key",
            "description": "Private Key Content"
          },
          "pkey_passphrase": {
            "type": "string",
            "title": "Password",
            "description": "Password for Private Key (if applicable)"
          },
          "overwrite": {
            "type": "boolean",
            "title": "Overwrite Existing Key",
            "default": false,
            "description": "If a key already exists, overwrite it with this one."
          }
        },
        "required": ["pkey"]
      },
      "uiSchema": {
        "pkey": {
          "ui:widget": "textarea"
        },
        "pkey_passphrase": {
          "ui:widget": "password"
        }
      }
    }
  ]
}