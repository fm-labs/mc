{
  "actions": [
    {
      "id": "sync",
      "name": "Sync Template",
      "type": "form",
      "inputSchema": {
        "type": "object",
        "properties": {
          "force": {
            "type": "boolean",
            "default": false,
            "description": "Force synchronization even if there are no detected changes.",
            "title": "Force"
          }
        }
      }
    },
    {
      "id": "configure",
      "name": "Configure Environment",
      "type": "form",
      "inputSchema": {
        "type": "object",
        "properties": {
          "environment": {
            "type": "object",
            "title": "Override Environment Variables",
            "description": "Set environment variables for the application stack.",
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      }
    },
    {
      "id": "deploy",
      "name": "Deploy Stack",
      "type": "form",
      "inputSchema": {
        "type": "object",
        "properties": {
          "background": {
            "type": "boolean",
            "default": true,
            "description": "Run deployment in the background.",
            "title": "Run in Background"
          },
          "confirm": {
            "type": "boolean",
            "default": true,
            "description": "Confirm publishing this item.",
            "title": "Confirm"
          }
        }
      }
    },
    {
      "id": "template",
      "name": "View Template",
      "type": "view"
    },
    {
      "id": "stackfile",
      "name": "View Stackfile",
      "type": "view"
    }
  ]
}