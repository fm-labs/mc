{
  "actions": [
    {
      "id": "sync",
      "name": "Sync Template",
      "type": "form",
      "inputSchema": {
        "type": "object",
        "properties": {
          "force": {
            "type": "boolean",
            "default": false,
            "description": "Force synchronization even if there are no detected changes.",
            "title": "Force"
          }
        }
      }
    },
    {
      "id": "configure",
      "name": "Configure Environment",
      "type": "form",
      "inputSchema": {
        "type": "object",
        "properties": {
          "environment": {
            "type": "object",
            "title": "Override Environment Variables",
            "description": "Set environment variables for the application stack.",
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      }
    },
    {
      "id": "deploy",
      "name": "Deploy Stack",
      "type": "form",
      "inputSchema": {
        "type": "object",
        "properties": {
          "build": {
            "type": "boolean",
            "default": false,
            "description": "Force build of images before deploying the stack.",
            "title": "Build Images"
          },
          "remove_orphans": {
            "type": "boolean",
            "default": false,
            "description": "Remove containers for services not defined in the template.",
            "title": "Remove Orphans"
          },
          "background": {
            "type": "boolean",
            "default": false,
            "description": "Run deployment in the background.",
            "title": "Run in Background"
          },
          "confirm": {
            "type": "boolean",
            "default": false,
            "description": "Confirm publishing this item.",
            "title": "Confirm"
          }
        }
      }
    },
    {
      "id": "redeploy",
      "name": "Redeploy Stack",
      "type": "form",
      "inputSchema": {
        "type": "object",
        "properties": {
          "sync": {
            "type": "boolean",
            "default": false,
            "description": "Sync before deploy.",
            "title": "Sync"
          },
          "build": {
            "type": "boolean",
            "default": false,
            "description": "Force build of images before deploying the stack.",
            "title": "Build Images"
          },
          "remove_orphans": {
            "type": "boolean",
            "default": false,
            "description": "Remove containers for services not defined in the template.",
            "title": "Remove Orphans"
          },
          "background": {
            "type": "boolean",
            "default": false,
            "description": "Run redeployment in the background.",
            "title": "Run in Background"
          },
          "confirm": {
            "type": "boolean",
            "default": false,
            "description": "Confirm redeploying this item.",
            "title": "Confirm"
          }
        }
      }
    },
    {
      "id": "destroy",
      "name": "Destroy Stack",
      "type": "form",
      "inputSchema": {
        "type": "object",
        "properties": {
          "background": {
            "type": "boolean",
            "default": false,
            "description": "Run redeployment in the background.",
            "title": "Run in Background"
          },
          "confirm": {
            "type": "boolean",
            "default": false,
            "description": "Confirm redeploying this item.",
            "title": "Confirm"
          }
        }
      }
    },
    {
      "id": "template",
      "name": "Template",
      "type": "view"
    },
    {
      "id": "stackfile",
      "name": "Stackfile",
      "type": "view"
    }
  ]
}