{
  "title": "App Stack",
  "description": "An application stack deployment configuration.",
  "version": "1.0.0",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "type": {
      "type": "string",
      "description": "Deployment method for the application.",
      "enum": [
        "container",
        "compose",
        "stack",
        "kubernetes",
        "podman"
      ],
      "default": "compose"
    },
    "label": {
        "type": "string",
        "description": "A human-friendly label for the application stack."
    },
    "repository": {
      "type": "object",
      "description": "Repository information for the application stack.",
      "properties": {
        "url": {
          "type": "string",
          "format": "uri",
          "description": "Repository URL, e.g. 'git://user/repo'."
        },
        "branch": {
          "type": "string",
          "description": "The branch to use from the repository. Defaults to 'main'."
        },
        "path": {
          "type": "string",
          "description": "The base path within the repository where the stackfile is located. Defaults to '/'."
        },
        "private": {
          "type": "boolean",
          "description": "Requires authentication.",
          "default": false
        },
        "auth": {
          "type": "object",
          "description": "Authentication information for private repositories.",
          "properties": {
            "username": {
              "type": "string",
              "description": "Username for repository authentication."
            },
            "password": {
              "type": "string",
              "description": "Password for repository authentication."
            }
          }
        }
      },
      "required": [
        "url"
      ],
      "additionalProperties": false
    },
    "stackfile": {
      "type": "string",
      "description": "Name of stackfile."
    },
    "target_node": {
      "type": "string",
      "description": "The deployment target node."
    },
    "domain_name": {
      "type": "string",
      "description": "Optional domain name. Required if routing is enabled.",
      "pattern": "^(?:[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?)(?:\\.(?:[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?))*\\.?$"
    },
    "proxy_enabled": {
      "type": "boolean",
      "default": false,
      "description": "Enables routing."
    },
    "proxy_http_enabled": {
      "type": "boolean",
      "default": false,
      "description": "Enable HTTP routing."
    },
    "proxy_https_enabled": {
      "type": "boolean",
      "default": false,
      "description": "Enable HTTPS routing."
    },
    "proxy_service_name": {
      "type": "string",
      "description": "Name of the container service to attach the router.",
      "minLength": 1
    },
    "proxy_container_port": {
      "type": "integer",
      "description": "Container port the app listens on.",
      "minimum": 1,
      "maximum": 65535
    },
    "proxy_network_name": {
      "type": "string",
      "description": "Name of the Docker network Traefik is on. Defaults to 'traefik'.",
      "minLength": 1
    },
    "environment": {
      "type": "object",
      "description": "Environment variables to set for the application stack.",
      "additionalProperties": {
        "type": "string"
      }
    }
  },
  "required": [
    "type"
  ]
}
