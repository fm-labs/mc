{
  "title": "App Stack",
  "description": "An application stack deployment configuration.",
  "version": "1.0.0",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "source_type": {
      "type": "string",
      "description": "The type of source for the application stack.",
      "enum": [
        "directory",
        "git"
      ]
    },
    "source_url": {
      "type": "string",
      "format": "uri",
      "description": "Repository URL, e.g. 'git://user/repo'."
    },
    "stackfile": {
      "type": "string",
      "description": "Path to the stackfile within the repository."
    },
    "deployment_method": {
      "type": "string",
      "description": "Deployment method for the application.",
      "enum": [
        "container",
        "compose",
        "stack",
        "kubernetes",
        "podman"
      ],
      "default": "compose"
    },
    "deployment_target": {
      "type": "string",
      "description": "The deployment target node."
    },
    "domain_name": {
      "type": "string",
      "description": "Optional domain name. Required if routing is enabled.",
      "pattern": "^(?:[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?)(?:\\.(?:[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?))*\\.?$"
    },
    "proxy_enabled": {
      "type": "boolean",
      "default": false,
      "description": "Enables routing."
    },
    "proxy_http_enabled": {
      "type": "boolean",
      "default": false,
      "description": "Enable HTTP routing."
    },
    "proxy_https_enabled": {
      "type": "boolean",
      "default": false,
      "description": "Enable HTTPS routing."
    },
    "proxy_service_name": {
      "type": "string",
      "description": "Name of the container service to attach the router.",
      "minLength": 1
    },
    "proxy_container_port": {
      "type": "integer",
      "description": "Container port the app listens on.",
      "minimum": 1,
      "maximum": 65535
    },
    "proxy_network_name": {
      "type": "string",
      "description": "Name of the Docker network Traefik is on. Defaults to 'traefik'.",
      "minLength": 1
    },
    "environment": {
      "type": "object",
      "description": "Environment variables to set for the application stack.",
      "additionalProperties": {
        "type": "string"
      }
    }
  },
  "required": [
    "source_url",
    "deployment_target"
  ]
}
