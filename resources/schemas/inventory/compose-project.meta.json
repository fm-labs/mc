{
  "actions": [
    {
      "id": "sync",
      "name": "Sync Project",
      "type": "form",
      "inputSchema": {
        "type": "object",
        "properties": {
          "force": {
            "type": "boolean",
            "default": false,
            "description": "Force synchronization even if there are no detected changes.",
            "title": "Force"
          },
          "reset": {
            "type": "boolean",
            "default": false,
            "description": "Reset the repo. This will discard local changes.",
            "title": "Reset"
          }
        }
      }
    },
    {
      "id": "configure",
      "name": "Configure Project",
      "type": "form",
      "inputSchema": {
        "type": "object",
        "properties": {
          "confirm": {
            "type": "boolean",
            "default": true,
            "description": "Confirm updating this item.",
            "title": "Confirm"
          }
        }
      }
    },
    {
      "id": "deploy",
      "name": "Deploy Project",
      "type": "form",
      "inputSchema": {
        "type": "object",
        "properties": {
          "confirm": {
            "type": "boolean",
            "default": true,
            "description": "Confirm publishing this item.",
            "title": "Confirm"
          }
        }
      }
    }
  ]
}