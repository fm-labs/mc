{
  "type": "object",
  "title": "Host",
  "description": "Server host inventory item",
  "version": "1.0.0",
  "properties": {
    "network": {
      "type": "string",
      "title": "Network name"
    },
    "hostname": {
      "type": "string",
      "title": "Hostname"
    },
    "ip_address": {
      "type": "string",
      "title": "IP Address"
    },
    "public_dns_name": {
      "type": "string",
      "title": "Public DNS Name"
    },
    "public_ip": {
      "type": "string",
      "title": "Public IP Address"
    },
    "ssh_enabled": {
      "type": "boolean",
      "title": "Enable SSH",
      "default": false
    },
    "ssh_user": {
      "type": "string",
      "title": "SSH User",
      "default": ""
    },
    "ssh_hostname": {
      "type": "string",
      "title": "SSH Hostname (if different)",
      "default": ""
    },
    "ssh_port": {
      "type": "integer",
      "title": "SSH Port (default 22)"
    },
    "ssh_key_name": {
      "type": "string",
      "title": "SSH Key Name",
      "default": ""
    },
    "ssh_key_path": {
      "type": "string",
      "title": "SSH Key Path (deprecated)",
      "default": ""
    },
    "autoconnect": {
      "type": "boolean",
      "title": "Auto-connect",
      "default": false
    },
    "monitoring_enabled": {
      "type": "boolean",
      "title": "Enable Monitoring (ping and fact gathering)",
      "default": false
    },
    "tunnel_enabled": {
      "type": "boolean",
      "title": "SSH Tunnel Enabled",
      "default": false
    },
    "tunnel_autoconnect": {
      "type": "boolean",
      "title": "SSH Tunnel auto-connect",
      "default": false
    },
    "tunnel_forward_specs": {
      "type": "string",
      "title": "Tunnel Forwarding Specifications",
      "description": "Comma-separated list. Example: 'L8080:localhost:80,R8443:localhost:443'",
      "default": ""
    },
    "container_host_enabled": {
      "type": "boolean",
      "title": "Enable Container Host",
      "default": false
    },
    "container_engine": {
      "type": "string",
      "title": "Container Engine",
      "enum": [
        "docker",
        "podman"
      ],
      "default": "docker"
    },
    "webstack_enabled": {
      "type": "boolean",
      "title": "Enable Webstack",
      "default": false
    },
    "webstack_traefik_enabled": {
      "type": "boolean",
      "title": "Enable Traefik on Webstack",
      "default": false
    }
  },
  "required": [
    "hostname",
    "ip_address"
  ]
}