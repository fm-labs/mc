{
  "name": "Host",
  "pluralName": "Hosts",
  "description": "A single host entry in the inventory.",
  "icon": "server",
  "actions": [
    {
      "id": "ping",
      "name": "Ping",
      "type": "form",
      "inputSchema": {
        "type": "object",
        "properties": {
          "count": {
            "type": "integer",
            "title": "Count",
            "default": 4,
            "description": "Number of echo requests to send"
          },
          "timeout": {
            "type": "integer",
            "title": "Timeout (seconds)",
            "default": 5,
            "description": "Time to wait for a response"
          }
        },
        "required": []
      }
    },
    {
      "id": "ssh_connect",
      "name": "Probe SSH Connection",
      "type": "form",
      "inputSchema": {
        "type": "object",
        "properties": {
          "port": {
            "type": "integer",
            "title": "Port",
            "default": 22,
            "description": "SSH port to connect to"
          },
          "username": {
            "type": "string",
            "title": "Username",
            "description": "Username for SSH authentication"
          },
          "timeout": {
            "type": "integer",
            "title": "Timeout (seconds)",
            "default": 5,
            "description": "Time to wait for a connection"
          }
        }
      }
    },
    {
      "id": "run_playbook",
      "name": "Run Ansible Playbook",
      "type": "form",
      "inputSchema": {
        "type": "object",
        "properties": {
          "playbook": {
            "type": "string",
            "title": "Playbook",
            "description": "Name of built-in playbook to run",
            "enum": [
              "baseline-debian",
              "baseline-debian-security",
              "dockerhost-debian",
              "podmanhost-debian",
              "facts-all",
              "facts-diskusage",
              "hello-world",
              "wireguard-server"
            ]
          },
          "extra_vars": {
            "type": "string",
            "title": "Extra Variables",
            "description": "Additional variables to pass to the playbook in JSON format"
          }
        },
        "required": [
          "playbook"
        ]
      }
    },
    {
      "id": "setup_container_host",
      "name": "Setup container host",
      "type": "form",
      "inputSchema": {
        "type": "object",
        "properties": {
          "container_runtime": {
            "type": "string",
            "title": "Container Runtime",
            "description": "Container runtime to install",
            "enum": [
              "docker",
              "podman"
            ]
          }
        },
        "required": []
      }
    },
    {
      "id": "setup_webstack",
      "name": "Setup Webstack",
      "type": "form",
      "inputSchema": {
        "type": "object",
        "properties": {
          "project_name": {
            "type": "string",
            "title": "Project Name",
            "description": "Name of the related project (deprecated)"
          }
        },
        "required": [
          "project_name"
        ]
      }
    }
  ]
}