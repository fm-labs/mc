{
  "actions": [
    {
      "id": "ping",
      "name": "Ping",
      "type": "form",
      "inputSchema": {
        "type": "object",
        "properties": {
          "count": {
            "type": "integer",
            "title": "Count",
            "default": 4,
            "description": "Number of echo requests to send"
          },
          "timeout": {
            "type": "integer",
            "title": "Timeout (seconds)",
            "default": 5,
            "description": "Time to wait for a response"
          }
        },
        "required": []
      }
    },
    {
      "id": "scan",
      "name": "Scan",
      "type": "form",
      "inputSchema": {
        "type": "object",
        "properties": {
          "immediate": {
            "type": "boolean",
            "default": true,
            "description": "Run the scan immediately"
          }
        }
      }
    },
    {
      "id": "",
      "name": "",
      "type": "separator"
    },
    {
      "id": "delete",
      "name": "Delete",
      "type": "form",
      "variant": "destructive",
      "inputSchema": {
        "type": "object",
        "properties": {
          "confirm": {
            "type": "boolean",
            "const": true,
            "title": "I confirm that I want to delete this DNS Domain"
          }
        },
        "required": [
          "confirm"
        ]
      }
    }
  ]
}