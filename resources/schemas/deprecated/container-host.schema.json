{
  "type": "object",
  "title": "Container Host",
  "description": "Docker host inventory item",
  "version": "1.0.0",
  "$icon": "docker",
  "properties": {
    "engine": {
      "type": "string",
      "title": "Docker Engine",
      "enum": [
        "docker",
        "podman"
      ],
      "default": "docker"
    },
    "url": {
      "type": "string",
      "title": "Container Host URL"
    },
    "autoconnect": {
      "type": "boolean",
      "title": "Auto-connect",
      "default": true
    }
  },
  "required": [
    "engine",
    "url"
  ]
}